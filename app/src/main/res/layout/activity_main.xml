<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#100E44">

    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/logo_triemphu"
        android:scaleType="fitCenter"
        android:alpha="0.4" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center">

        <LinearLayout
            android:id="@+id/layoutMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI LÀ TRIỆU PHÚ"
                android:textColor="#FFD700"
                android:textSize="36sp"
                android:textStyle="bold"
                android:layout_marginBottom="40dp"
                android:shadowColor="#000000"
                android:shadowDx="3"
                android:shadowDy="3"
                android:shadowRadius="10"
                android:gravity="center"/>

            <Button
                android:id="@+id/btnStart"
                android:layout_width="260dp"
                android:layout_height="65dp"
                android:text="BẮT ĐẦU CHƠI"
                android:backgroundTint="#4CAF50"
                android:layout_marginBottom="15dp"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnLeaderboard"
                android:layout_width="260dp"
                android:layout_height="65dp"
                android:text="BẢNG XẾP HẠNG"
                android:backgroundTint="#FFC107"
                android:layout_marginBottom="15dp"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <Button
                android:id="@+id/btnExit"
                android:layout_width="260dp"
                android:layout_height="65dp"
                android:text="THOÁT GAME"
                android:backgroundTint="#F44336"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutGame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnPause"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Tạm dừng"
                    android:layout_margin="2dp"
                    android:backgroundTint="#FFC107"
                    android:textColor="#000000"
                    android:textSize="10sp"/>

                <Button
                    android:id="@+id/btnRestart"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Chơi lại"
                    android:layout_margin="2dp"
                    android:backgroundTint="#2196F3"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#44000000"
                android:padding="12dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtCurrentLevel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CÂU: 1/30"
                    android:textColor="#FFD700"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtCurrentMoney"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="$ 0"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="end" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/txtTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30"
                    android:textColor="#FFD700"
                    android:textSize="45sp"
                    android:textStyle="bold"
                    android:shadowColor="#000000"
                    android:shadowRadius="5"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="20dp">

                    <Button android:id="@+id/btn5050" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="50:50" android:layout_margin="2dp" android:backgroundTint="#FF9800" android:textSize="12sp" android:textStyle="bold" android:textColor="#FFFFFF" />
                    <Button android:id="@+id/btnCall" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Gọi" android:layout_margin="2dp" android:backgroundTint="#FF9800" android:textSize="12sp" android:textStyle="bold" android:textColor="#FFFFFF" />
                    <Button android:id="@+id/btnAudience" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Khán giả" android:layout_margin="2dp" android:backgroundTint="#FF9800" android:textSize="12sp" android:textStyle="bold" android:textColor="#FFFFFF" />
                </LinearLayout>
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txtQuestion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Đang tải câu hỏi..."
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="25dp"
                        android:shadowColor="#000000"
                        android:shadowDx="2"
                        android:shadowDy="2"
                        android:shadowRadius="5"
                        android:padding="10dp"/>

                    <Button android:id="@+id/btnAnswerA" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="10dp" android:text="Đáp án A" android:backgroundTint="#1A237E" android:textSize="16sp" android:textColor="#FFFFFF" android:textAllCaps="false"/>
                    <Button android:id="@+id/btnAnswerB" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="10dp" android:text="Đáp án B" android:backgroundTint="#1A237E" android:textSize="16sp" android:textColor="#FFFFFF" android:textAllCaps="false"/>
                    <Button android:id="@+id/btnAnswerC" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="10dp" android:text="Đáp án C" android:backgroundTint="#1A237E" android:textSize="16sp" android:textColor="#FFFFFF" android:textAllCaps="false"/>
                    <Button android:id="@+id/btnAnswerD" android:layout_width="match_parent" android:layout_height="55dp" android:text="Đáp án D" android:backgroundTint="#1A237E" android:textSize="16sp" android:textColor="#FFFFFF" android:textAllCaps="false"/>
                </LinearLayout>
            </ScrollView>

        </LinearLayout>
    </LinearLayout>
</FrameLayout>